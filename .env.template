# ==========================================
# CẤU HÌNH API LLM CHO BENCHMARK (LightRAG, v.v.)
# ==========================================

# 1. BẮT BUỘC: API Key của bạn
OPENAI_API_KEY="sk-your-api-key"

# 2. TÙY CHỌN: Tên model bạn muốn dùng (Ví dụ: qwen2-7b-instruct, kimi-k2-instruct)
# Nếu để trống, code tự dùng gpt-4o-mini
LLM_MODEL_NAME="moonshotai/kimi-k2-instruct"

# 3. TÙY CHỌN: Thay đổi Endpoint nếu bạn dùng API proxy hoặc Local
# OPENAI_BASE_URL="http://localhost:8000/v1"

# 4. TÙY CHỌN (Gần như BẮT BUỘC nếu dùng Local/Nvidia): Tên model Embedding
# Ví dụ: nvidia/nv-embedqa-e5-v5
EMBEDDING_MODEL_NAME="nvidia/nv-embedqa-e5-v5"  # hoặc "nvidia/nv-embed-v1"
EMBEDDING_DIM=4096 # Chỉnh lại kích thước vector phù hợp (Ví dụ: nv-embed-v1 là 4096, text-embedding-3-small là 1536)
